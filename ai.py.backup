# Browser automation for web scraping (no APIs needed)
try:
    from selenium import webdriver
    from selenium.webdriver.common.by import By
    from selenium.webdriver.support.ui import WebDriverWait
    from selenium.webdriver.support import expected_conditions as EC
    from selenium.webdriver.chrome.options import Options
    HAS_SELENIUM = True
except ImportError:
    HAS_SELENIUM = False

# Beautiful Soup for parsing
try:
    from bs4 import BeautifulSoup
    HAS_BS4 = True
except ImportError:
    HAS_BS4 = False

class WebEngine:
    def __init__(self):
        self.user_agent = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36'
        self.driver = None
        self.search_cache = {}

    def _get_driver(self):
        if not HAS_SELENIUM:
            return None
        try:
            if self.driver is None:
                options = Options()
                options.add_argument("--headless")
                options.add_argument("--disable-blink-features=AutomationControlled")
                options.add_argument(f"user-agent={self.user_agent}")
                options.add_argument("--disable-gpu")
                options.add_argument("--no-sandbox")
                self.driver = webdriver.Chrome(options=options)
            return self.driver
        except:
            return None

    def _fetch(self, url, headers=None):
        request_headers = {'User-Agent': self.user_agent}
        if headers:
            request_headers.update(headers)
        try:
            req = urllib.request.Request(url, headers=request_headers)
            with urllib.request.urlopen(req, timeout=10) as response:
                return response.read().decode('utf-8', errors='ignore')
        except:
            return ""

    def _search_google(self, query):
        try:
            driver = self._get_driver()
            if not driver:
                return []
            
            driver.get(f"https://www.google.com/search?q={urllib.parse.quote(query)}")
            time.sleep(2)
            
            results = []
            soup = BeautifulSoup(driver.page_source, 'html.parser')
            
            for item in soup.find_all('div', class_='g')[:5]:
                title_elem = item.find('h3')
                url_elem = item.find('a')
                desc_elem = item.find('div', class_='VwiC3b')
                
                if title_elem and url_elem and url_elem.get('href'):
                    title = title_elem.get_text(strip=True)
                    url = url_elem.get('href').split('?')[0] if '?' in url_elem.get('href') else url_elem.get('href')
                    desc = desc_elem.get_text(strip=True) if desc_elem else ""
                    
                    if title and url and not url.startswith('/'):
                        results.append({"title": title, "url": url, "description": desc})
            
            return results
        except Exception as e:
            return []

    def _search_fallback(self, query):
        try:
            encoded = urllib.parse.quote(query)
            page = self._fetch(f"https://search.brave.com/search?q={encoded}")
            if page and HAS_BS4:
                soup = BeautifulSoup(page, 'html.parser')
                results = []
                for item in soup.find_all('div', class_='snippet')[:5]:
                    title = item.find('a', class_='result-header')
                    desc = item.find('p', class_='snippet')
                    if title and desc:
                        results.append({
                            "title": title.get_text(strip=True),
                            "url": title.get('href', ''),
                            "description": desc.get_text(strip=True)
                        })
                return results
            return []
        except:
            return []

    def search(self, query):
        try:
            if query in self.search_cache:
                return self.search_cache[query]
            
            encoded = urllib.parse.quote(query)
            
            # Try browser-based search first
            results = []
            if HAS_SELENIUM:
                results = self._search_google(query)
            
            if not results:
                results = self._search_fallback(query)

            # Fetch Wikipedia for context
            wiki_res = ""
            try:
                w_search = json.loads(self._fetch(f"https://en.wikipedia.org/w/api.php?action=opensearch&search={encoded}&limit=1&format=json"))
                if w_search[1]:
                    title = w_search[1][0]
                    w_sum = json.loads(self._fetch(f"https://en.wikipedia.org/api/rest_v1/page/summary/{urllib.parse.quote(title.replace(' ', '_'))}"))
                    if w_sum.get("type") != "disambiguation":
                        wiki_res = w_sum.get("extract", "")
            except:
                pass

            cache_result = (wiki_res, results)
            self.search_cache[query] = cache_result
            return cache_result
        except:
            return None, []
    
    def close(self):
        if self.driver:
            try:
                self.driver.quit()
            except:
                pass
            self.driver = None

class CodeEngine:
    def __init__(self):
        self.last_code = ""
       self.code_templates = {
           "python": {
               "calculator": 'def calculate(expr):\n    allowed = "0123456789+-*/().% "\n    if any(c not in allowed for c in expr):\n        raise ValueError("Invalid expression")\n    return eval(expr, {"__builtins__": {}}, {})\n\nwhile True:\n    expr = input("calc> ").strip()\n    if expr.lower() in {"q", "quit", "exit"}:\n        break\n    try:\n        print(calculate(expr))\n    except Exception as e:\n        print(f"Error: {e}")',
               "hello": 'name = input("What is your name? ")\nprint(f"Hello, {name}!")',
               "loop": 'for i in range(1, 6):\n    print(f"Number: {i}")',
           },
           "javascript": {
               "calculator": 'function calculate(expr) {\n  const allowed = /^[0-9+\\-*/.()% ]+$/;\n  if (!allowed.test(expr)) throw new Error("Invalid");\n  return eval(expr);\n}\n\nlet expr;\nwhile ((expr = prompt("calc> ")) !== null && !["q", "quit", "exit"].includes(expr)) {\n  try {\n    console.log(calculate(expr));\n  } catch (e) {\n    console.log("Error: " + e.message);\n  }\n}',
               "hello": 'const name = prompt("What is your name?");\nalert(`Hello, ${name}!`);',
               "loop": 'for (let i = 1; i <= 5; i++) {\n  console.log(`Number: ${i}`);\n}',
           },
           "html": {
               "website": '''<!DOCTYPE html>
<html lang="en">
<head>
 <meta charset="utf-8">
 <meta name="viewport" content="width=device-width, initial-scale=1">
 <title>My Page</title>
 <style>
   body { font-family: Arial, sans-serif; margin: 2rem; line-height: 1.5; }
   h1 { color: #333; }
 </style>
</head>
<body>
 <h1>Welcome</h1>
 <p>Edit this page to make it yours.</p>
</body>
</html>''',
           },
           "bash": {
               "hello": 'echo "Hello, World!"',
               "loop": 'for i in {1..5}; do\n  echo "Number: $i"\ndone',
           },
           "java": {
               "hello": 'public class Hello {\n  public static void main(String[] args) {\n    System.out.println("Hello, World!");\n  }\n}',
           },
           "csharp": {
               "hello": 'using System;\n\nclass Program {\n  static void Main() {\n    Console.WriteLine("Hello, World!");\n  }\n}',
           },
           "cpp": {
               "hello": '#include <iostream>\nusing namespace std;\n\nint main() {\n  cout << "Hello, World!" << endl;\n  return 0;\n}',
           }
       }

   def detect_language(self, text):
       text_lower = text.lower()
       if "python" in text_lower or "py " in text_lower:
           return "python"
       elif "javascript" in text_lower or "js " in text_lower or "node" in text_lower:
           return "javascript"
       elif "html" in text_lower or "website" in text_lower:
           return "html"
       elif "bash" in text_lower or "shell" in text_lower:
           return "bash"
       elif "java " in text_lower or "java::" in text_lower:
           return "java"
       elif "csharp" in text_lower or "c#" in text_lower or "dotnet" in text_lower:
           return "csharp"
       elif "cpp" in text_lower or "c++" in text_lower:
           return "cpp"
       return "python"

   def handle(self, text):
       text_lower = text.lower().strip()

       if text_lower.startswith(("run python:", "execute python:")):
           code = text.split(":", 1)[1].strip()
           return self.run_python(code)

       if text_lower.startswith(("save code as ", "save python as ")):
           match = re.match(r"save (?:code|python) as\s+([^\s:]+)\s*:?\s*(.*)", text, re.IGNORECASE | re.DOTALL)
           if not match:
               return "Use: save code as filename.py: print('hello')"
           filename, code = match.groups()
           code = code.strip() or self.last_code
           return self.save_code(filename, code)

       if text_lower.startswith(("explain code:", "review code:")):
           code = text.split(":", 1)[1].strip()
           return self.explain_code(code)

       if self._looks_like_code_request(text_lower):
           return self.write_code(text)

       return None

   def _looks_like_code_request(self, text_lower):
       triggers = (
           "write code", "make code", "create code", "generate code",
           "write a program", "make a program", "create a program",
           "python script", "javascript", "html", "bash", "java", "c#",
           "tkinter", "function that", "code a ", "write a", "script for"
       )
       return any(trigger in text_lower for trigger in triggers)

   def write_code(self, prompt):
       text = prompt.lower()
       lang = self.detect_language(prompt)
        
       # Check for template matches
       for template_type, keywords in [("calculator", ["calculator", "calc", "compute"]),
                                      ("hello", ["hello", "greet", "hi "]),
                                      ("loop", ["loop", "for", "iterate", "repeat"]),
                                      ("website", ["website", "html", "web page"])]:
           if any(kw in text for kw in keywords) and template_type in self.code_templates.get(lang, {}):
               code = self.code_templates[lang][template_type]
               self.last_code = code
               ext = "py" if lang == "python" else "js" if lang == "javascript" else "html" if lang == "html" else "sh" if lang == "bash" else lang
               return f"Here is {lang} code:\n\n```{lang}\n{code}\n```\n\nSay `save code as filename.{ext}` to save it."

       # Generic response
       default = self.code_templates[lang].get("hello", "# Generated code\nprint('Code here')")
       self.last_code = default
       return f"Here is {lang} code:\n\n```{lang}\n{default}\n```\n\nDescribe what you want more specifically and I can generate better code."

   def save_code(self, filename, code):
       if not re.match(r"^[A-Za-z0-9_.-]+$", filename):
           return "Use a simple filename with letters, numbers, dots, dashes, or underscores."

       if not any(filename.endswith(ext) for ext in [".py", ".txt", ".html", ".css", ".js", ".sh", ".java", ".cs", ".cpp"]):
           filename += ".py"

       path = os.path.abspath(filename)
       cwd = os.path.abspath(os.getcwd())
       if not path.startswith(cwd + os.sep):
           return "I can only save files inside this project folder."

       with open(path, "w", encoding="utf-8") as f:
           f.write(code)
           if not code.endswith("\n"):
               f.write("\n")

       self.last_code = code
       return f"✓ Saved code to {path}"

   def run_python(self, code):
       if len(code) > 4000:
           return "That snippet is too large to run from chat. Save it to a file first."

       try:
           result = subprocess.run(
               ["python3", "-c", code],
               capture_output=True,
               text=True,
               timeout=8,
               cwd=os.getcwd()
           )
       except subprocess.TimeoutExpired:
           return "Python timed out after 8 seconds."
       except Exception as exc:
           return f"Could not run Python: {exc}"

       output = result.stdout.strip()
       error = result.stderr.strip()
       if result.returncode == 0:
           return output or "Python ran successfully with no output."
       return f"Python exited with code {result.returncode}.\n\n{error or output}"

   def explain_code(self, code):
       if not code:
           return "Paste code after `explain code:`."

       lines = code.splitlines()
       notes = [f"This snippet has {len(lines)} line(s)."]
       if "import " in code:
           notes.append("→ It imports external or standard-library modules.")
       if "def " in code:
           notes.append("→ It defines one or more functions.")
       if "class " in code:
           notes.append("→ It defines one or more classes.")
       if "eval(" in code or "exec(" in code:
           notes.append("⚠ Caution: uses eval/exec, can run arbitrary code.")
       if "subprocess" in code:
           notes.append("⚠ Caution: starts system processes.")
       if "open(" in code:
           notes.append("→ It performs file I/O operations.")
       return "\n".join(notes)

class ContextManager:
    def __init__(self):
        self.history = []
        self.topics = {}
        self.max_history = 50

    def add_interaction(self, user_input, bot_response):
        self.history.append({"user": user_input, "bot": bot_response, "time": datetime.datetime.now()})
        if len(self.history) > self.max_history:
            self.history.pop(0)

    def track_topic(self, topic, info):
        if topic not in self.topics:
            self.topics[topic] = []
        self.topics[topic].append({"info": info, "time": datetime.datetime.now()})

    def get_context(self, query):
        related = []
        query_words = set(query.lower().split())
        for entry in self.history[-10:]:
            entry_words = set(entry["user"].lower().split()) | set(entry["bot"].lower().split())
            overlap = query_words & entry_words
            if overlap:
                related.append(entry)
        return related

    def save_session(self, filename="session.json"):
        data = {
            "history": self.history,
            "topics": self.topics,
            "timestamp": datetime.datetime.now().isoformat()
        }
        try:
            with open(filename, "w") as f:
                json.dump(data, f, indent=2, default=str)
            return f"✓ Session saved to {filename}"
        except Exception as e:
            return f"Error saving session: {e}"


class SmartBrain:
    def __init__(self):
        self.web = WebEngine()
        self.code = CodeEngine()
        self.context = ContextManager()
        self.conversational_patterns = {
            r"\b(hello|hi|hey|yo|gday|g'day|greetings)\b": ["Hey! How's it going?", "Hi! What can I help with?", "Yo! Ready to code or search?"],
            r"\b(how are you|how ya going|how ya goin|how ya goin')\b": ["Doing great, fully local! You?", "Living in RAM. How about you?"],
            r"\bwho are you\b": ["I'm NEON AI, fully local. No cloud, no LLM dependency, just web scraping and code."],
            r"\bwhat can you do\b": ["I can search the web with Selenium, code in Python/JS/HTML/Bash/Java/C#/C++, run Python, explain code, and track context."],
            r"\b(thanks|thank you|tysm|ty)\b": ["No problem!", "Anytime!", "Happy to help!"],
            r"\b(save session|export|backup)\b": ["Saving your session...", "Creating backup..."]
        }

    def get_response(self, text):
        text_lower = text.lower().strip()
        
        if text_lower == "help":
            return (
                "🤖 NEON AI - Fully Local Assistant\n\n"
                "I can:\n"
                "  • Search the web (via Selenium, no APIs)\n"
                "  • Generate code (Python, JavaScript, HTML, Bash, Java, C#, C++)\n"
                "  • Execute Python snippets\n"
                "  • Explain code\n"
                "  • Track conversation context\n"
                "  • Do math\n\n"
                "Examples:\n"
                "  'search the web for AI news'\n"
                "  'write python code for a calculator'\n"
                "  'run python: print(2 + 2)'\n"
                "  'explain code: def hello(): print(\"hi\")'\n"
                "  'save session'\n"
            )

        # 1. Code assistant (no LLM needed, templates handle it)
        if self.code._looks_like_code_request(text_lower):
            answer = self.code.handle(text)
            if answer:
                self.context.add_interaction(text, answer)
                return answer

        # 2. Conversational patterns
        for pattern, responses in self.conversational_patterns.items():
            if re.search(pattern, text_lower):
                response = random.choice(responses)
                self.context.add_interaction(text, response)
                if "save" in text_lower and "session" in text_lower:
                    return self.context.save_session()
                return response

        # 3. System info
        if "time" in text_lower:
            response = f"🕐 {datetime.datetime.now().strftime('%I:%M %p on %A')}"
            self.context.add_interaction(text, response)
            return response
        if "system" in text_lower or "info" in text_lower:
            response = f"System: {platform.system()} | Host: {platform.node()} | Python: {platform.python_version()}"
            self.context.add_interaction(text, response)
            return response

        # 4. Math
        if re.search(r'[\d\+\-\*\/\(\)\^]', text) and any(c in text for c in "+-*/^%"):
            try:
                expr = text.replace("^", "**")
                res = eval(re.sub(r'[^0-9\+\-\*\/\(\)\.\%\s\*\^a-zA-Z]', '', expr), {"__builtins__": None}, {k: getattr(math, k) for k in dir(math) if not k.startswith("_")})
                response = f"🧮 {res}"
                self.context.add_interaction(text, response)
                return response
            except:
                pass

        # 5. Web search
        wiki, snippets = self.web.search(text)
        if snippets or wiki:
            result_lines = []
            if wiki:
                result_lines.append(f"📚 Wiki: {html.unescape(wiki)}\n")
            if snippets:
                result_lines.append("🔍 Web Results:")
                for index, item in enumerate(snippets, 1):
                    title = item.get("title") or "Untitled"
                    url = item.get("url") or ""
                    description = item.get("description") or ""
                    result_lines.append(f"\n{index}. {title}")
                    if description:
                        result_lines.append(f"   {description}")
                    if url:
                        result_lines.append(f"   {url}")
            response = "\n".join(result_lines)
            self.context.add_interaction(text, response)
            self.context.track_topic(text, snippets)
            return response

        # 6. Fallback
        response = (
            f"❓ I don't understand '{text}'.\n\n"
            "Try: 'help', 'search web for ...', 'write python code for ...', 'run python: ...', or 'explain code: ...'"
        )
        self.context.add_interaction(text, response)
        
        # Try sentiment analysis if available
        if TB:
            blob = TB(text)
            if blob.sentiment.polarity < -0.5:
                response += "\n\n(I sense a negative sentiment in that message)"
            elif blob.sentiment.polarity > 0.5:
                response += "\n\n(I sense a positive sentiment in that message)"

        return response

class NeonUI:
    def __init__(self, root):
        self.root = root
        self.root.title("NEON CORE")
        self.root.geometry("800x900")
        self.root.configure(bg="#000000")

        self.orange = "#FF5F00"
        self.cyan = "#00FFCC"
        self.brain = SmartBrain()
        self.attached_path = None

        self._build_layout()

    def _build_layout(self):
        # 1. Header Bar
        header = tk.Frame(self.root, bg="#080808", height=60)
        header.pack(side=tk.TOP, fill=tk.X)
        header.pack_propagate(False)

        tk.Label(header, text="NEON CORE AI", bg="#080808", fg=self.orange, font=("Consolas", 16, "bold")).pack(side=tk.LEFT, padx=20)
        self.status_dot = tk.Label(header, text="●", bg="#080808", fg="#00FF00", font=("Arial", 14))
        self.status_dot.pack(side=tk.RIGHT, padx=(0, 5))
        self.status_text = tk.Label(header, text="SYSTEM ONLINE", bg="#080808", fg="#555555", font=("Consolas", 9))
        self.status_text.pack(side=tk.RIGHT, padx=(0, 20))

        # 2. Chat Display Area
        chat_frame = tk.Frame(self.root, bg="#000000")
        chat_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)

        self.display = scrolledtext.ScrolledText(
            chat_frame, bg="#000000", fg="#FFFFFF", font=("Consolas", 12),
            bd=0, wrap=tk.WORD, state='disabled', padx=15, pady=15,
            highlightthickness=1, highlightbackground="#111111"
        )
        self.display.pack(fill=tk.BOTH, expand=True)
        self.display.tag_config("user_tag", foreground=self.orange, font=("Consolas", 12, "bold"))
        self.display.tag_config("bot_tag", foreground=self.cyan, font=("Consolas", 12, "bold"))

        # 3. Interaction Area (Footer)
        footer = tk.Frame(self.root, bg="#000000", height=80) # Dark base
        footer.pack(side=tk.BOTTOM, fill=tk.X, padx=10, pady=10)
        footer.pack_propagate(False)

        input_container = tk.Frame(footer, bg="#111111", highlightthickness=1, highlightbackground="#333333")
        input_container.pack(fill=tk.BOTH, expand=True)

        self.btn_file = tk.Button(input_container, text="+", bg="#111111", fg=self.orange, bd=0, font=("Arial", 18), activebackground="#1a1a1a", command=self.pick_file)
        self.btn_file.pack(side=tk.LEFT, padx=10)

        # Fix for the entry bar - removed pady and added ipady to fill container vertically
        self.entry = tk.Entry(input_container, bg="#111111", fg="#FFFFFF", font=("Consolas", 13), bd=0, insertbackground=self.orange)
        self.entry.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        self.entry.bind("<Return>", lambda e: self.send())

        self.btn_send = tk.Button(input_container, text="➜", bg="#111111", fg=self.orange, bd=0, font=("Arial", 18), activebackground="#1a1a1a", command=self.send)
        self.btn_send.pack(side=tk.RIGHT, padx=10)

    def pick_file(self):
        path = filedialog.askopenfilename()
        if path:
            self.attached_path = path
            self.set_status(f"LOADED: {os.path.basename(path)}", self.orange)

    def set_status(self, text, color="#555555"):
        self.status_text.config(text=text.upper(), fg=color)
        self.status_dot.config(fg="#FF8C00" if "THINKING" in text.upper() else "#00FF00")

    def send(self):
        text = self.entry.get().strip()
        if not text and not self.attached_path: return

        self.add_msg("YOU", text, "user_tag")
        self.entry.delete(0, tk.END)
        self.set_status("THINKING...", self.orange)

        threading.Thread(target=self._process, args=(text,)).start()

    def _process(self, text):
        # Handle file if attached
        if self.attached_path:
            filename = os.path.basename(self.attached_path)
            ext = os.path.splitext(self.attached_path)[1].lower()
            resp = ""
            if ext in ['.png', '.jpg', '.jpeg', '.webp'] and HAS_PIL:
                with Image.open(self.attached_path) as img:
                    resp = f"Image '{filename}' detected. It's {img.width}x{img.height} pixels. Ready for instructions."
            else:
                try:
                    with open(self.attached_path, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read(1000)
                        resp = f"File '{filename}' loaded. Preview:\n\n{content}..."
                except: resp = "Error reading the file."
            self.attached_path = None
            self.root.after(0, lambda: self.add_msg("NEON", resp, "bot_tag"))
        else:
            resp = self.brain.get_response(text)
            self.root.after(0, lambda: self.add_msg("NEON", resp, "bot_tag"))

        self.root.after(0, lambda: self.set_status("SYSTEM ONLINE"))

    def add_msg(self, sender, msg, tag):
        self.display.config(state='normal')
        self.display.insert(tk.END, f"\n{sender}\n", tag)
        self.display.insert(tk.END, f"{msg}\n")
        self.display.config(state='disabled')
        self.display.yview(tk.END)

if __name__ == "__main__":
    root = tk.Tk()
    NeonUI(root)
    root.mainloop()
